# --- Email subscription (Resend) ---
# Required for the subscribe form to work. Get an API key at https://resend.com
RESEND_API_KEY=re_xxxx

# Optional: Resend audience ID – add subscribers to this audience (create in Resend dashboard)
# RESEND_AUDIENCE_ID=

# Optional: "From" for new-subscriber notifications to sangbackyeo@gmail.com. Use a verified domain in Resend, or leave unset to use Resend's test sender.
# RESEND_FROM=Cubing with Micah <notify@yourdomain.com>

# Site URL for RSS feed links (e.g. https://yoursite.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Micah's photo on the About page (e.g. /micah.jpg if you add public/micah.jpg). Leave unset for initials avatar.
# NEXT_PUBLIC_MICAH_IMAGE=/micah.jpg

# Optional: YouTube channel for "Latest from Micah" and Videos page. Use the channel ID (UC...) or the handle so videos match youtube.com/@mikayeo/videos.
# NEXT_PUBLIC_YOUTUBE_CHANNEL_ID=@mikayeo
