# Resend (optional – required for email subscription to work)
# Get key at https://resend.com
RESEND_API_KEY=re_xxxx
# Optional: Resend audience ID to add subscribers to a specific audience
RESEND_AUDIENCE_ID=

# Site URL for RSS feed links (e.g. https://yoursite.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Micah's photo on the About page (e.g. /micah.jpg if you add public/micah.jpg). Leave unset for initials avatar.
# NEXT_PUBLIC_MICAH_IMAGE=/micah.jpg
